generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ADMIN
  STAFF
}

enum OrderStatus {
  NEW
  CONFIRMED
  PREPARING
  READY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum OrderType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CARD
  ON_PICKUP
  ON_DELIVERY
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  CUSTOMER_ORDER_CONFIRMATION
  CUSTOMER_PAYMENT_CONFIRMATION
  CUSTOMER_ORDER_READY
  CUSTOMER_ORDER_DELIVERED
  CUSTOMER_ORDER_CANCELLED
  RESTAURANT_NEW_ORDER
  RESTAURANT_PAYMENT_RECEIVED
  RESTAURANT_ORDER_CANCELLED
}

enum NotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum ReservationStatus {
  NEW
  CONFIRMED
  CANCELLED
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  phone        String?
  passwordHash String?
  role         UserRole @default(CUSTOMER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
}

model Category {
  id        String    @id @default(cuid())
  slug      String    @unique
  name      String
  image     String?
  sortOrder Int       @default(0)
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  id          String          @id @default(cuid())
  categoryId  String
  name        String
  description String
  price       Int
  image       String?
  active      Boolean         @default(true)
  soldOut     Boolean         @default(false)
  sortOrder   Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    Category        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  options     ProductOption[]
  orderItems  OrderItem[]
}

model ProductOption {
  id            String  @id @default(cuid())
  productId     String
  name          String
  priceModifier Int     @default(0)
  required      Boolean @default(false)
  sortOrder     Int     @default(0)
  product       Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String               @id @default(cuid())
  orderNumber     String               @unique
  userId          String?
  customerName    String
  customerPhone   String
  customerEmail   String
  customerAddress String?
  orderType       OrderType
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus        @default(PENDING)
  stripeSessionId String?              @unique
  paymentIntentId String?
  note            String?
  adminNote       String?
  total           Int
  status          OrderStatus          @default(NEW)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]
  statusHistory   OrderStatusHistory[]
  notificationLogs NotificationLog[]
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String?
  productName String
  quantity    Int
  unitPrice   Int
  totalPrice  Int
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
}

model SiteSettings {
  id              Int      @id @default(1)
  restaurantName  String   @default("Ellstorps Krog")
  phone           String
  email           String
  address         String
  logo            String?
  heroImage       String?
  deliveryEnabled Boolean  @default(true)
  pickupEnabled   Boolean  @default(true)
  minimumOrder    Int      @default(0)
  deliveryFee     Int      @default(49)
  facebookUrl     String?
  instagramUrl    String?
  tiktokUrl       String?
  notificationEmail             String?
  emailSenderName               String?
  emailSenderAddress            String?
  customerEmailsEnabled         Boolean  @default(true)
  restaurantEmailsEnabled       Boolean  @default(true)
  notifyCustomerOrderConfirmation   Boolean @default(true)
  notifyCustomerPaymentConfirmation Boolean @default(true)
  notifyCustomerOrderReady          Boolean @default(true)
  notifyCustomerOrderDelivered      Boolean @default(true)
  notifyCustomerOrderCancelled      Boolean @default(true)
  notifyRestaurantNewOrder          Boolean @default(true)
  notifyRestaurantPaymentReceived   Boolean @default(true)
  notifyRestaurantOrderCancelled    Boolean @default(true)
  metaTitle                 String?
  metaDescription           String?
  ogImage                   String?
  keywords                  String?
  googleAnalyticsId         String?
  googleTagManagerId        String?
  googleAdsConversionId     String?
  metaPixelId               String?
  googleAnalyticsEnabled    Boolean  @default(false)
  googleTagManagerEnabled   Boolean  @default(false)
  googleAdsEnabled          Boolean  @default(false)
  metaPixelEnabled          Boolean  @default(false)
  stripeEnabled             Boolean  @default(false)
  stripeTestMode            Boolean  @default(true)
  stripePublishableKeyTest  String?
  stripeSecretKeyTest       String?
  stripeWebhookSecretTest   String?
  stripePublishableKeyLive  String?
  stripeSecretKeyLive       String?
  stripeWebhookSecretLive   String?
  updatedAt       DateTime @updatedAt
}

model OpeningHours {
  id        String @id @default(cuid())
  dayOfWeek Int
  openTime  String
  closeTime String
  isClosed  Boolean @default(false)

  @@unique([dayOfWeek])
}

model DeliveryZone {
  id           String @id @default(cuid())
  name         String
  postalCodes  String
  deliveryFee  Int    @default(49)
  minimumOrder Int    @default(0)
}

model NotificationLog {
  id           String                     @id @default(cuid())
  orderId      String?
  type         NotificationType
  recipient    String
  subject      String
  status       NotificationDeliveryStatus @default(PENDING)
  errorMessage String?
  resendId     String?
  retryCount   Int                        @default(0)
  sentAt       DateTime?
  createdAt    DateTime                   @default(now())
  order        Order?                     @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

model Reservation {
  id         String            @id @default(cuid())
  name       String
  phone      String
  email      String
  guestCount Int
  date       String
  time       String
  comment    String?
  status     ReservationStatus @default(NEW)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([date])
  @@index([status])
  @@index([createdAt])
}
